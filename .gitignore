# ──────────────────────────────────────────── 
*.pem
*.cer
*.key
aws-credentials.json
.aws/
docker-compose.override.yml

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform.tfvars

# Docker
.docker/

# Elastic Beanstalk
.elasticbeanstalk/

# Nginx
nginx/ssl/

node_modules
.git
venv
__pycache__
*.pyc
.env
dist
build