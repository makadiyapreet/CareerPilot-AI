# ============================================
# CareerPilot AI - .gitignore
# ============================================

# ──────────────────────────────────────────── 
#  Python
# ──────────────────────────────────────────── 
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
.env.local
ENV/

# Python distribution / packaging
*.manifest
*.spec
MANIFEST

# PyInstaller
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ──────────────────────────────────────────── 
#  Node.js / Frontend
# ──────────────────────────────────────────── 
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
.vite/
*.local

# ──────────────────────────────────────────── 
#  Environment Variables (CRITICAL - DO NOT COMMIT)
# ──────────────────────────────────────────── 
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
backend/.env
frontend/.env

# ──────────────────────────────────────────── 
#  Database Files
# ──────────────────────────────────────────── 
*.db
*.sqlite3
*.sqlite
*.db-journal
*.db-shm
*.db-wal

# ──────────────────────────────────────────── 
#  IDE / Editor
# ──────────────────────────────────────────── 
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
*.code-workspace
.project
.classpath
.settings/

# ──────────────────────────────────────────── 
#  macOS
# ──────────────────────────────────────────── 
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ──────────────────────────────────────────── 
#  Windows
# ──────────────────────────────────────────── 
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ──────────────────────────────────────────── 
#  Linux
# ──────────────────────────────────────────── 
*~
.fuse_hidden*
.nfs*

# ──────────────────────────────────────────── 
#  ML / AI Models & Data
# ──────────────────────────────────────────── 
ai_ml/models/*.pkl
ai_ml/models/*.joblib
ai_ml/models/*.h5
ai_ml/models/*.pt
ai_ml/models/*.pth
ai_ml/models/*.onnx
ai_ml/datasets/*.csv
ai_ml/datasets/*.json
!ai_ml/models/.gitkeep
!ai_ml/interview_prep/questions_db.json
!ai_ml/skill_gap/skill_taxonomy.json
!ai_ml/roadmap_generator/roadmap_templates.json

# ──────────────────────────────────────────── 
#  Uploads & User Data
# ──────────────────────────────────────────── 
backend/uploads/*
!backend/uploads/.gitkeep

# ──────────────────────────────────────────── 
#  Logs
# ──────────────────────────────────────────── 
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ──────────────────────────────────────────── 
#  Misc
# ──────────────────────────────────────────── 
*.bak
*.tmp
*.temp
*.orig
.vercel
.netlify

# ──────────────────────────────────────────── 
